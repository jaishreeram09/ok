#include<iostream>
using namespace std;
int swap(int &x,int &y)
{
    int z;
    z=x;
    x=y;
    y=z;
}
int main()
{
    int num1,num2;
    cout<<"Enter two numbers: "<<endl;
    cin>>num1>>num2;
    cout<<"Numbers before swapping are: "<<endl;
    cout<<"num1 = "<<num1<<endl;
    cout<<"num2 = "<<num2<<endl;
    swap(num1,num2);
    cout<<"Numbers after swapping are: "<<endl;
    cout<<"num1 = "<<num1<<endl;
    cout<<"num2 = "<<num2<<endl;
    return 0;
}
