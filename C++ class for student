#include<iostream>
using namespace std;
class student
{
    private:
        int id;
        string name;
    public:
        void getdata(void)
        {
            cout<<"Enter Student ID: ";
            cin>>id;
            cout<<"Enter Student Name: ";
            cin>>name;
        }
        void printdata(void)
        {
            cout<<"Student ID is: "<<id<<endl;
            cout<<"Student Name is: "<<name<<endl;
        }
};
int main()
{
    student s1,s2,s3;
    s1.getdata();
    s2.getdata();
    s3.getdata();
    s1.printdata();
    s2.printdata();
    s3.printdata();
    return 0;
}
